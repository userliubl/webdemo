{
  "envId": "your-env-id",
  "framework": {
    "name": "nextjs",
    "plugins": {
      "client": {
        "use": "@cloudbase/framework-plugin-website",
        "inputs": {
          "buildCommand": "npm run build",
          "outputPath": "out",
          "cloudPath": "/",
          "errorDocument": "404.html",
          "ignore": []
        }
      }
    }
  }
}
